{
  "name": "gpu-earn",
  "version": "1.0.0",
  "description": "Платформа для заработка на видеокартах с платными туториалами",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "node db-init.js",
