    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.7.0",
    "stripe": "^12.0.0",
    "node-cron": "^3.0.2",
    "pdfkit": "^0.13.0",
    "multer": "^1.4.5-lts.1"
  },
